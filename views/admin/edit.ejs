<!DOCTYPE html>
  <html lang="en">
  <head><%- include('../partials/head', { title: 'Edit Artwork' }) %></head>
  <body>
    <%- include('../partials/nav') %>
    <main>
      <h1>Edit Artwork</h1>
      <form action="/admin/<%= artwork._id %>?_method=PUT" method="POST" enctype="multipart/form-data">
        <label>Title <input type="text" name="title" value="<%= artwork.title %>" required /></label>
        <label>Slug <input type="text" name="slug" value="<%= artwork.slug %>" required /></label>
        <label>Medium <input type="text" name="medium" value="<%= artwork.medium || '' %>" /></label>
        <label>Year <input type="number" name="year" value="<%= artwork.year || '' %>" /></label>
        <label>Description <textarea name="description"><%= artwork.description || '' %></textarea></label>
        <label>New Image (leave blank to keep current) <input type="file" name="image" accept=".jpg,.jpeg,.png,.pdf"
   /></label>
        <img src="/<%= artwork.imagePath %>" alt="current" style="max-width:200px" />
        <button type="submit">Update</button>
      </form>
    </main>
  </body>
  </html>