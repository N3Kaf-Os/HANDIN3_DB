 <!DOCTYPE html>
  <html lang="en">
  <head><%- include('../partials/head', { title: 'Admin' }) %></head>
  <body>
    <div class="layout">
      <%- include('../partials/nav') %>
      <main class="main-content">
        <div class="admin-header">
          <h1>Artworks</h1>
          <a href="/admin/new" class="btn">+ New</a>
        </div>
        <table>
          <thead>
            <tr>
              <th>Title</th>
              <th>Medium</th>
              <th>Year</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% artworks.forEach(artwork => { %>
              <tr>
                <td><%= artwork.title %></td>
                <td><%= artwork.medium %></td>
                <td><%= artwork.year %></td>
                <td>
                  <div class="action-links">
                    <a href="/admin/<%= artwork._id %>/edit" class="btn-edit">Edit</a>
                    <form action="/admin/<%= artwork._id %>?_method=DELETE" method="POST">
                      <button type="submit" class="btn-danger">Delete</button>
                    </form>
                  </div>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </main>
    </div>
  </body>
  </html>