<!DOCTYPE html>
<html lang="en">
<head><%- include('partials/head', { title: 'Enter' }) %></head>
<body>
  <div class="layout">
    <main class="main-content" style="display:flex; flex-direction:column; align-items:center; justify-content:center; min-height:80vh; text-align:center;">
      <h1 style="font-family: 'Fraunces', serif; font-size: 3rem;">Portfolio</h1>
      <p style="max-width: 40ch; margin: 1rem 0 2rem;">A collection of drawings, paintings, and prints.</p>
      <form action="/enter" method="POST">
        <!-- Honeypot: hidden from humans, attractive to bots. -->
        <input
          type="text"
          name="website"
          tabindex="-1"
          autocomplete="off"
          aria-hidden="true"
          style="position:absolute; left:-9999px; width:1px; height:1px; opacity:0;"
        />
        <button type="submit" class="btn">Enter</button>
      </form>
    </main>
  </div>
</body>
</html>