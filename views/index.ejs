<!DOCTYPE html>
  <html lang="en">
  <head><%- include('partials/head', { title: 'Home' }) %></head>
  <body>
    <div class="layout">
      <%- include('partials/nav') %>
      <main class="main-content">
        <h1>Recent Work</h1>
        <div class="gallery-grid">
          <% artworks.forEach(artwork => { %>
            <a href="/artworks/<%= artwork.slug %>" class="gallery-card">
              <img src="/<%= artwork.imagePath %>" alt="<%= artwork.title %>" />
              <div class="card-meta">
                <div class="card-title"><%= artwork.title %></div>
                <div class="card-sub"><%= artwork.medium %> &mdash; <%= artwork.year %></div>
              </div>
            </a>
          <% }) %>
        </div>
      </main>
    </div>
  </body>
  </html>